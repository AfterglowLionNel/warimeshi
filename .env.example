# ========================================
# warimeshi 環境変数サンプル
# このファイルを .env.local にコピーして値を埋めてください。
# 本番は /etc/warimeshi.env で systemd の EnvironmentFile に渡しています。
# ========================================

# ---- Database ----
# Docker Compose で起動した Postgres に合わせたデフォルト値
DATABASE_URL=postgres://warimeshi:warimeshi@localhost:5432/warimeshi

# ---- Auth.js ----
# `openssl rand -base64 32` で生成
AUTH_SECRET=your-secret-key-generate-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# 招待リンクのパスワード暗号化に使う鍵 (AUTH_SECRET と分離)
# `openssl rand -base64 32` で生成
INVITE_PASSWORD_SECRET=your-invite-password-secret-generate-with-openssl-rand-base64-32

# ---- リダイレクト ----
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Google OAuth ----
# https://console.cloud.google.com/ で取得
AUTH_GOOGLE_ID=your-google-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your-google-client-secret

# ---- LINE OAuth ----
# https://developers.line.biz/console/ で取得
AUTH_LINE_ID=your-line-channel-id
AUTH_LINE_SECRET=your-line-channel-secret

# ---- Upstash Redis (任意 / レート制限) ----
# 設定されていない場合は in-memory にフォールバックする
# https://console.upstash.com/ で取得
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
